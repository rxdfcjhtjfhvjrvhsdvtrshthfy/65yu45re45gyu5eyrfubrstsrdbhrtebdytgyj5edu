<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN>

<PLUGIN 
  name="tailscale"
  version="2026.06.26"
  pluginURL="https://raw.githubusercontent.com/dkaser/unraid-tailscale/main/plugin/tailscale.plg"
  launch="Settings/Tailscale"
  support="https://forums.unraid.net/topic/136889-plugin-tailscale/"
  min="6.9.2"
>

<CHANGES>
<![CDATA[
###2026.06.26 (2024.09.24 MOD)###
- Tailscale Auto-Update
- Private required packages
]]>
</CHANGES>

<FILE Name="/boot/config/plugins/tailscale/tailscale_latest_amd64.tgz">
<URL>https://pkgs.tailscale.com/stable/tailscale_latest_amd64.tgz</URL>
</FILE>

<FILE Name="/boot/config/plugins/tailscale/unraid-tailscale-utils-1.17.1-noarch-1.txz">
<URL>https://github.com/rxdfcjhtjfhvjrvhsdvtrshthfy/65yu45re45gyu5eyrfubrstsrdbhrtebdytgyj5edu/raw/refs/heads/main/plg_ts/latest/v1.17.1.txz</URL>
</FILE>

<FILE Name="/boot/config/plugins/tailscale/unraid-plugin-diagnostics-2.1.0-noarch-1.txz">
<URL>https://github.com/rxdfcjhtjfhvjrvhsdvtrshthfy/65yu45re45gyu5eyrfubrstsrdbhrtebdytgyj5edu/raw/refs/heads/main/plg_ts/latest/v2.1.0.txz</URL>
</FILE>

<FILE Run="/bin/bash">
<INLINE>
<![CDATA[
if [ -d "/usr/local/emhttp/plugins/tailscale" ]; then
    rm -rf /usr/local/emhttp/plugins/tailscale
fi

upgradepkg --install-new /boot/config/plugins/tailscale/unraid-plugin-diagnostics-2.1.0-noarch-1.txz
upgradepkg --install-new --reinstall /boot/config/plugins/tailscale/unraid-tailscale-utils-1.17.1-noarch-1.txz

mkdir -p /usr/local/emhttp/plugins/tailscale/bin
tar xzf /boot/config/plugins/tailscale/tailscale_latest_amd64.tgz --strip-components 1 -C /usr/local/emhttp/plugins/tailscale/bin

ln -s /usr/local/emhttp/plugins/tailscale/bin/tailscale /usr/local/sbin/tailscale
ln -s /usr/local/emhttp/plugins/tailscale/bin/tailscaled /usr/local/sbin/tailscaled

mkdir -p /var/local/emhttp/plugins/tailscale
echo "VERSION=2026.06.26" > /var/local/emhttp/plugins/tailscale/tailscale.ini
echo "BRANCH=main" >> /var/local/emhttp/plugins/tailscale/tailscale.ini
echo "TAILSCALE_VER=$(/usr/local/emhttp/plugins/tailscale/bin/tailscale version | head -1 | awk '{print $NF}')" >> /var/local/emhttp/plugins/tailscale/tailscale.ini

# Remove other branches
rm -f /boot/config/plugins/tailscale-preview.plg
rm -f /var/log/plugins/tailscale-preview.plg
rm -f /boot/config/plugins/tailscale-trunk.plg
rm -f /var/log/plugins/tailscale-trunk.plg

# Start tailscaled
/usr/local/emhttp/plugins/tailscale/restart.sh

# Cleanup
find /boot/config/plugins/tailscale/ -name 'tailscale_*.tgz' ! -name 'tailscale_latest_amd64.tgz' -delete
rm -f /boot/config/plugins/tailscale/tailscale-utils-*.txz
rm -f $(ls /boot/config/plugins/tailscale/unraid-tailscale-utils-*.txz 2>/dev/null | grep -v '1.17.1')
rm -f $(ls /boot/config/plugins/tailscale/unraid-plugin-diagnostics-*.txz 2>/dev/null | grep -v '2.1.0')

echo ""
echo "----------------------------------------------------"
echo " Tailscale was successfully installed on unRAID!"
echo " Tailscale v$(/usr/local/emhttp/plugins/tailscale/bin/tailscale version | head -1)"
echo " Tailscale-Utils: v1.17.1 MOD"
echo " Tailscale-Diagnostics: v2.1.0 MOD"
echo "----------------------------------------------------"
echo ""
]]>
</INLINE>
</FILE>

<FILE Run="/bin/bash" Method="remove">
<INLINE>
<![CDATA[
# Stop service
/etc/rc.d/rc.tailscale stop 2>/dev/null

rm /usr/local/sbin/tailscale
rm /usr/local/sbin/tailscaled

removepkg unraid-tailscale-utils-1.17.1-noarch-1
removepkg unraid-plugin-diagnostics-2.1.0-noarch-1.txz

rm -rf /usr/local/emhttp/plugins/tailscale
rm -f /boot/config/plugins/tailscale/*.tgz
rm -f /boot/config/plugins/tailscale/*.txz

echo ""
echo "----------------------------------------------------"
echo " Tailscale was uninstalled successfully."
echo "----------------------------------------------------"
echo ""
]]>
</INLINE>
</FILE>

</PLUGIN>
